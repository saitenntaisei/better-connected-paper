# Citation provider strategy:
#   (unset / any other value) → hybrid: OpenAlex primary + OpenCitations
#                                secondary supplement (fills arxiv-DOI refs)
#   openalex                  → OpenAlex only (no hybrid supplement)
#   semanticscholar | s2      → Semantic Scholar only
# OpenAlex is ~10 req/s anonymous; OpenCitations is polite-pool friendly;
# Semantic Scholar is 1 req / 3s without a key and is therefore no longer
# wired into the hybrid cascade by default.
CITATION_PROVIDER=

# Set CITATION_HYBRID=false to force OpenAlex-only even when CITATION_PROVIDER is unset.
CITATION_HYBRID=

# Hybrid secondary selector. Defaults to opencitations; set semanticscholar
# or s2 to swap in Semantic Scholar (emergency fallback — requires an API
# key to stay within rate limits). Set none/off to disable the secondary.
CITATION_SECONDARY=

# Hybrid tertiary selector. Disabled by default. Set to semanticscholar to
# opt back into the S2 last-resort supplement (only safe with an API key
# that raises the 1 req / 3s anonymous ceiling).
CITATION_TERTIARY=

# Join the OpenAlex "polite pool" for higher/faster rate limits (optional).
# Also used as the polite-pool mailto for the OpenCitations secondary.
OPENALEX_EMAIL=

# OpenCitations access token — optional, lifts the anonymous rate cap.
# Request at https://opencitations.net/accesstoken
OPENCITATIONS_TOKEN=

# Semantic Scholar API key — only consulted when CITATION_PROVIDER,
# CITATION_SECONDARY, or CITATION_TERTIARY explicitly selects S2.
# Request at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Postgres connection URL
# Matches docker-compose credentials for local dev
DATABASE_URL=postgres://bcp:bcp@localhost:5432/bcp?sslmode=disable

# Backend server port
PORT=8080

# Frontend Vite dev server exposes /api proxy to this URL
VITE_API_BASE=http://localhost:8080
