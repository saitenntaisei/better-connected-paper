# Semantic Scholar API key (optional, higher rate limits)
# Request at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Postgres connection URL
# Matches docker-compose credentials for local dev
DATABASE_URL=postgres://bcp:bcp@localhost:5432/bcp?sslmode=disable

# Backend server port
PORT=8080

# Frontend Vite dev server exposes /api proxy to this URL
VITE_API_BASE=http://localhost:8080
